generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  employers    Employer[]
  shifts       Shift[]
  payPeriods   PayPeriod[]
  sessions     Session[]
  awardLevels  AwardLevel[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Employer {
  id                  String        @id @default(cuid())
  userId              String
  name                String
  // Fallback base rate (used when a day has no AwardLevel attached)
  hourlyRate          Float
  // "weekly" | "fortnightly" | "monthly"
  payCycle            String        @default("fortnightly")
  // ISO date string (YYYY-MM-DD) — reference start of a pay period
  payPeriodStartDate  String
  // days after period end when pay arrives (e.g. 4 = paid 4 days after period closes)
  paydayOffsetDays    Int           @default(4)
  defaultBreakMinutes Int           @default(30)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts              Shift[]
  awardLevels         AwardLevel[]
}

// User-defined classification levels under a workplace award.
// e.g. "P5 — Pharmacy Assistant Grade 5" with a base hourly rate.
// One employee can have many; each PayPeriodDay can be tagged with one.
model AwardLevel {
  id          String         @id @default(cuid())
  userId      String
  employerId  String
  code        String         // e.g. "P5"
  description String?        // optional — "Pharmacy Assistant Grade 5"
  baseRate    Float          // base hourly rate at weekday (100%)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer    Employer       @relation(fields: [employerId], references: [id], onDelete: Cascade)
  days        PayPeriodDay[]

  @@unique([employerId, code])
  @@index([userId])
}

// TODO: Shift model kept for legacy /shifts page. Not the primary workflow anymore.
// The PayPeriod + PayPeriodDay models are the new primary data model.
model Shift {
  id           String   @id @default(cuid())
  userId       String
  employerId   String
  shiftDate    String
  startTime    String
  endTime      String
  breakMinutes Int      @default(0)
  totalHours   Float
  estimatedPay Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer     Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

model PayPeriod {
  id        String         @id @default(cuid())
  userId    String
  name      String?        // user-supplied label, optional
  startDate String         // YYYY-MM-DD
  endDate   String         // YYYY-MM-DD
  // "active" | "closed"
  status    String         @default("active")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  days      PayPeriodDay[]
}

model PayPeriodDay {
  id            String      @id @default(cuid())
  payPeriodId   String
  date          String      // YYYY-MM-DD
  workHours     Float       @default(0)
  // Penalty-rate category: "weekday" | "saturday" | "sunday" | "public_holiday" | "custom"
  dayType       String      @default("weekday")
  // Optional link to an AwardLevel; null falls back to employer.hourlyRate
  awardLevelId  String?
  // Stored rate at time of entry — not recalculated if base rate changes later
  payRate       Float       @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  payPeriod     PayPeriod   @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  awardLevel    AwardLevel? @relation(fields: [awardLevelId], references: [id], onDelete: SetNull)

  @@index([awardLevelId])
}
